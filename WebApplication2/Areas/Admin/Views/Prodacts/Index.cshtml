@{
    ViewData["Title"] = "Dashboard";
}

<div class="text-center mt-5 mb-4">
    <h1 class="display-5 fw-bold">Welcome to the Admin Panel</h1>
    <p class="lead">Manage your application content and settings here.</p>
</div>

<div class="d-flex justify-content-end mb-3">
    <a href="/admin/Prodacts/Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Create New Product
    </a>
</div>

<table class="table table-striped table-bordered text-center align-middle">
    <thead class="table-primary">
        <tr>
            <th scope="col" style="width: 50px;">Id</th>
            <th scope="col">Name</th>
            <th scope="col">Description</th>
            <th scope="col">Status</th>
            <th scope="col">Image</th>
            <th scope="col">Category</th>
            <th scope="col" style="width: 150px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in ViewBag.Prodacts)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Status</td>
                <td>
                    <img src="~/Image/@item.Image" class="img-thumbnail" style="width:50px; height:50px; object-fit:cover;" />
                </td>
                <td>@item.CategoryName</td>
                <td>
                    <a href="/admin/Prodacts/Edit/@item.Id" class="btn btn-sm btn-primary me-1">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a href="/admin/Prodacts/Delete/@item.Id" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
