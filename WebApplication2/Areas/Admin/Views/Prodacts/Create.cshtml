@model WebApplication2.Models.Prodacts

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">إضافة منتج جديد</h5>
    </div>

    <form action="/Admin/Prodacts/Store" method="post" class="card-body" enctype="multipart/form-data">




        <div class="mb-3">

            <label class="form-label fw-bold">Name</label>
            <input name="Name" value="@Model.Name" class="form-control form-control-lg" placeholder="أدخل اسم التصنيف" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Status</label>
            <input name="Status" value="@Model.Status" class="form-control form-control-lg" placeholder= />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Image</label>
            <input type="file"  name="file" class="form-control form-control-lg" placeholder="أدخل اسم التصنيف" />
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Category</label>
            <select name="CategoryId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name", Model.CategoryId))">
                <option value="">-- اختر التصنيف --</option>
            </select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>


        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">إضافة</button>
        </div>
    </form>
</div>

