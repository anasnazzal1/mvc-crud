@model WebApplication2.Models.Category

<div class="card shadow-sm mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">إضافة تصنيف جديد</h5>
    </div>

    <form asp-area="Admin" asp-controller="Categoris" asp-action="Store"  method="post" class="card-body">
   

     

        <div class="mb-3">

            <label  class="form-label fw-bold"></label>
            <input  asp-for="Name" class="form-control form-control-lg" placeholder="أدخل اسم التصنيف" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label  class="form-label fw-bold"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="text-end">
            <button type="submit" class="btn btn-primary px-4">إضافة</button>
        </div>
    </form>
</div>

